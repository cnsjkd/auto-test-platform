# A2 自动化测试平台本地交付环境变量模板
# 复制为 .env 后按需调整；Windows PowerShell 可用 $env:NAME="value" 临时注入。

# 后端 SQLite dev mode，默认也会落到 backend/a2_automation.db。
A2_DB_URL=sqlite:///backend/a2_automation.db

# 后端 artifact 根目录，用于截图、UI XML、logcat 等证据文件。
A2_ARTIFACT_ROOT=backend/artifacts

# 前端 API Base。
# 本地开发使用 Vite dev proxy 时保持空值；生产静态托管建议同源反代 /api 与 /ws。
VITE_API_BASE_URL=

# 前端本地开发代理目标。
# 如果后端不在 8000 端口，改成当前后端地址并重启 Vite，避免代理到残留旧服务。
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# 默认关闭前端 mock fallback。
# 只有做纯 UI 演示时才设为 true；真实 A2 验收必须保持 false 或不设置。
VITE_ENABLE_MOCK_FALLBACK=false
